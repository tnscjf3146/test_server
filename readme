This is a first project to build a To-Do list,<br>
designed to help me master systematic development practices,<br>
project workflows and Git operations (including branching and merging)<br>

<br>
<br>

my_workspace/                  
├── .env                     <-- 🔒 [보안] DB 비밀번호, API 키 등을 숨겨두는 환경변수 파일<br>
├── .gitignore               <-- 🙈 깃허브에 올리지 않을 파일 목록 (보안 파일, 캐시 등)<br>
├── requirements.txt         <-- 📦 이 프로젝트를 실행하기 위해 필요한 파이썬 패키지 목록<br>
├── Dockerfile               <-- 🐳 배포나 독립적인 컨테이너 환경 구성을 위한 도커 설정 파일<br>
├── manage.py                <br>
│                            <br>
├── config/                  <-- ⚙️ [프로젝트 설정 및 관제탑]<br>
│   ├── settings/            <-- (실무에서는 settings.py를 하나만 쓰지 않고 쪼갭니다)<br>
│   │   ├── base.py          <-- 공통 설정<br>
│   │   ├── local.py         <-- 내 컴퓨터(로컬) 개발용 설정 (디버그 켜짐)<br>
│   │   └── prod.py          <-- 실제 서버 배포용 설정 (디버그 꺼짐, 보안 강화)<br>
│   ├── urls.py              <-- 전체 사이트의 최상위 라우터 (각 앱으로 트래픽 분산)<br>
│   └── wsgi.py              <br>
│                            <br>
├── accounts/                <-- 👤 [인증/회원 앱]<br>
│   ├── models.py            <-- 커스텀 User 모델 (이메일 로그인, 닉네임, 프로필 사진 필드)<br>
│   ├── forms.py             <-- 회원가입 폼, 로그인 폼, 비밀번호 변경 폼<br>
│   ├── views.py             <-- 로그인, 로그아웃, 마이페이지 처리 로직<br>
│   └── urls.py              <-- /accounts/login/, /accounts/signup/ 등의 주소<br>
│                            <br>
├── todos/                   <-- 📝 [메인 비즈니스 앱] (서비스의 핵심 목적)<br>
│   ├── models.py            <-- 할 일(Todo), 카테고리(Category) 모델<br>
│   ├── forms.py             <-- 새 할 일 작성, 수정 폼<br>
│   ├── views.py             <-- 할 일 목록 조회, 생성, 수정, 삭제(CRUD) 로직<br>
│   └── urls.py              <-- /todos/, /todos/1/edit/ 등의 주소<br>
│                            <br>
├── core/                    <-- 🛠️ [공통 유틸리티 앱] (여러 앱에서 같이 쓰는 도구 모음)<br>
│   ├── models.py            <-- 모든 모델에 공통으로 들어가는 '생성일/수정일(TimeStamped)' 추상화 모델<br>
│   └── utils.py             <-- 날짜 계산, 데이터 검증 등 여러 곳에서 쓰이는 공통 함수들<br>
│                            <br>
├── templates/               <-- 🎨 [전체 공통 화면 (Global Templates)]<br>
│   ├── base.html            <-- 모든 웹페이지의 기본 뼈대 (HTML `<head>`, 레이아웃)<br>
│   ├── includes/            <br>
│   │   ├── navbar.html      <-- 상단 네비게이션 바 (조각 코드)<br>
│   │   └── footer.html      <-- 하단 꼬리말 (조각 코드)<br>
│   ├── accounts/            <-- accounts 앱의 화면들 (login.html 등)<br>
│   └── todos/               <-- todos 앱의 화면들 (todo_list.html 등)<br>
│                            <br>
├── static/                  <-- 🖼️ [정적 파일] (개발자가 미리 넣어두는 변하지 않는 파일)<br>
│   ├── css/                 <-- 사이트 전체 디자인 (style.css)<br>
│   ├── js/                  <-- 사이트 전체 애니메이션/기능 (main.js)<br>
│   └── images/              <-- 로고 아이콘, 배경 이미지 등<br>
│                            <br>
└── media/                   <-- 📁 [사용자 업로드 파일] (동적으로 변하는 파일)<br>
    ├── profiles/            <-- 유저들이 올린 프로필 사진들<br>
    └── attachments/         <-- 게시글 등에 첨부한 파일들<br>